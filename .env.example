# ftp_sync secrets — copy this file to .env and fill in real values.
# .env must NEVER be committed to source control.
#
# One block per FTP connection.
# The env var names must match user_env and password_env in each config/ftp.*.yaml file.

# CLIENT01
FTP_USER_CLIENT01=your_username
FTP_PASSWORD_CLIENT01=your_password

# CLIENT02 (uncomment when adding a second connection)
# FTP_USER_CLIENT02=your_username
# FTP_PASSWORD_CLIENT02=your_password
